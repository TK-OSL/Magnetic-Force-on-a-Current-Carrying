            history: "<span class='font-bold text-amber-800'>ประวัติการค้นพบ:</span> หลักการของแรงแม่เหล็กที่กระทำต่อประจุไฟฟ้าและลวดตัวนำนี้ เป็นผลงานที่ถูกพัฒนาและคิดค้นโดย <b>อองเดร-มารี แอมแปร์ (André-Marie Ampère)</b> ผู้ค้นพบความสัมพันธ์ของแรงระหว่างลวดกระแสไฟฟ้า และ <b>เฮนดริก ลอเรนซ์ (Hendrik Lorentz)</b> ผู้คิดค้นสมการแรงลอเรนซ์ ($F = qv \\times B$) ซึ่งเป็นรากฐานของการคำนวณในแบบจำลองนี้",
            variablesTitle: "ตัวแปรในสมการ:",
            varF: "<span class='math-font font-bold text-red-600'>F</span> = ขนาดของแรงแม่เหล็ก (Newton, N)",
            varI: "<span class='math-font font-bold text-yellow-600'>I</span> = กระแสไฟฟ้า (Ampere, A)",
            varL: "<span class='math-font font-bold text-slate-800'>L</span> = ความยาวของลวดในบริเวณสนามแม่เหล็ก (Meter, m)",
            varB: "<span class='math-font font-bold text-blue-600'>B</span> = ความเข้มสนามแม่เหล็ก (Tesla, T)",
            varTheta: "<span class='math-font font-bold'>θ</span> = มุมระหว่างทิศของกระแสไฟฟ้า (<span class='math-font'>I</span>) กับสนามแม่เหล็ก (<span class='math-font'>B</span>)",
            rhrTitle: "วิธีใช้กฎมือขวา:",
            rhrDesc: "ชี้นิ้วทั้งสี่ไปตามทิศของกระแส (<span class='math-font'>I</span>) จากนั้นกำนิ้วไปหาทิศของสนามแม่เหล็ก (<span class='math-font'>B</span>) นิ้วหัวแม่มือจะชี้บอกทิศของแรง (<span class='math-font'>F</span>)",
            simTitle: "3D Simulation",
            btnTop: "ด้านบน",
            btnFront: "ด้านหน้า",
            btnSide: "ด้านข้าง",
            btnReset: "รีเซ็ต",
            legendTitle: "สัญลักษณ์ (Legend)",
            legendI: "กระแสไฟฟ้า",
            legendB: "สนามแม่เหล็ก",
            legendF: "แรงแม่เหล็ก",
            axisInfo: "แกน: <span class='text-red-500'>X</span>, <span class='text-green-500'>Y</span>, <span class='text-blue-500'>Z</span>",
            hint: "* สามารถคลิกซ้ายลากเพื่อหมุน, สกอร์ลเมาส์เพื่อซูม, คลิกขวาลากเพื่อเลื่อนกล้อง",
            ctrlTitle: "ปรับค่าตัวแปร",
            lblI: "กระแสไฟฟ้า (<span class='math-font'>I</span>)",
            lblB: "สนามแม่เหล็ก (<span class='math-font'>B</span>)",
            lblL: "ความยาวลวด (<span class='math-font'>L</span>)",
            lblTheta: "มุมระหว่าง <span class='math-font'>I</span> กับ <span class='math-font'>B</span> (θ)",
            angle0: "0° (ขนาน)",
            angle90: "90° (ตั้งฉาก)",
            angle180: "180° (สวนทาง)",
            calcTitle: "แสดงวิธีทำอย่างละเอียด",
            creditText: "พัฒนาโดย Gemini AI",
            // Strings specifically for the dynamic Math box
            mathEqTitle: "จากสมการ:",
            mathSub: "แทนค่าตัวแปร:",
            mathCalc: "คำนวณผลคูณและมุม:",
            mathResult: "สรุปขนาดของแรงแม่เหล็ก:",
            mathNewton: "นิวตัน (N)"
        }
    };

    /**
     * ==========================================
     * Application State & UI Integration
     * ==========================================
     */
    let currentLang = 'en'; // Default language is English

    // Holds the physics parameters updated by sliders
    let state = {
        I: 5.0,
        B: 2.0,
        L: 1.0,
        Theta: 90
    };

    // Cache DOM Elements for fast access
    const ui = {
        valI: document.getElementById('valI'), sliderI: document.getElementById('sliderI'),
        valB: document.getElementById('valB'), sliderB: document.getElementById('sliderB'),
        valL: document.getElementById('valL'), sliderL: document.getElementById('sliderL'),
        valTheta: document.getElementById('valTheta'), sliderTheta: document.getElementById('sliderTheta'),
        mathOutput: document.getElementById('math-output')
    };

    /**
     * Language Controller
     * Updates all text nodes based on the data-i18n attribute and toggles button UI state
     * @param {string} lang - 'en' or 'th'
     */
    function setLanguage(lang) {
        currentLang = lang;
        const dict = translations[lang];

        // 1. Iterate over all elements with a data-i18n attribute and update their innerHTML
        document.querySelectorAll('[data-i18n]').forEach(el => {
            const key = el.getAttribute('data-i18n');
            if (dict[key]) {
                el.innerHTML = dict[key];
            }
        });

        // 2. Update Toggle Button visual states
        const btnEn = document.getElementById('btn-lang-en');
        const btnTh = document.getElementById('btn-lang-th');
        
        if (lang === 'en') {
            btnEn.className = "lang-btn lang-btn-en active";
            btnTh.className = "lang-btn lang-btn-th inactive";
        } else {
            btnEn.className = "lang-btn lang-btn-en inactive";
            btnTh.className = "lang-btn lang-btn-th active";
        }

        // 3. Force re-render of dynamic math calculations to update localized strings inside it
        updateSimulation();
    }


    /**
     * ==========================================
     * Three.js Setup & Initialization
     * ==========================================
     */
    const container = document.getElementById('canvas-container');
    
    // Scene creation with dark background
    const scene = new THREE.Scene();
    scene.background = new THREE.Color(0x0f172a); // Matches Tailwind slate-900

    // Camera setup (Perspective)
    const camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 0.1, 1000);
    const defaultCameraPos = new THREE.Vector3(7, 5, 8);
    camera.position.copy(defaultCameraPos);

    // Standard WebGL Renderer for 3D objects
    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: false });
    renderer.setSize(container.clientWidth, container.clientHeight);
    renderer.setPixelRatio(window.devicePixelRatio);
    container.appendChild(renderer.domElement);

    // CSS2DRenderer setup for rendering standard HTML labels tracked to 3D positions
    // This allows text to remain crisp and readable regardless of camera angle
    const labelRenderer = new THREE.CSS2DRenderer();
    labelRenderer.setSize(container.clientWidth, container.clientHeight);
    labelRenderer.domElement.style.position = 'absolute';
    labelRenderer.domElement.style.top = '0px';
    labelRenderer.domElement.style.pointerEvents = 'none'; // Critical: allows clicking through to WebGL canvas for orbiting
    container.appendChild(labelRenderer.domElement);

    // OrbitControls for mouse interaction (pan, zoom, rotate)
    const controls = new THREE.OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;
    controls.dampingFactor = 0.05;

    // Lighting (Ambient + Directional)
    const ambientLight = new THREE.AmbientLight(0xffffff, 0.7);
    scene.add(ambientLight);
    const dirLight = new THREE.DirectionalLight(0xffffff, 0.8);
    dirLight.position.set(5, 10, 7);
    scene.add(dirLight);

    // Helpers to visualize the 3D space (Axes and Grid)
    const axesHelper = new THREE.AxesHelper(3);
    scene.add(axesHelper);
    const gridHelper = new THREE.GridHelper(10, 20, 0x334155, 0x1e293b);
    gridHelper.position.y = -0.01; // Offset slightly to prevent z-fighting with objects at y=0
    scene.add(gridHelper);

    /**
     * ==========================================
     * 3D Object Construction
     * ==========================================
     */
    
    /**
     * Helper to create an HTML label bound to the CSS2DRenderer
     */
    function createVectorLabel(text, className) {
        const div = document.createElement('div');
        div.className = `vector-label ${className}`;
        div.innerHTML = `<span class="math-font">${text}</span>`;
        return new THREE.CSS2DObject(div);
    }

    // --- 1. Magnetic Field (B) Vectors ---
    // The main magnetic field is defined as pointing along the positive X-axis
    const bColor = 0x3b82f6; // Blue
    const bArrowsGroup = new THREE.Group();
    scene.add(bArrowsGroup);
    
    // Main emphasized central arrow for B Field
    const mainBArrow = new THREE.ArrowHelper(new THREE.Vector3(1,0,0), new THREE.Vector3(0,0,0), 3, bColor, 0.5, 0.25);
    const labelB = createVectorLabel('B', 'label-b');
    labelB.position.set(3, 0.3, 0); // Offset to prevent overlap with arrow tip
    mainBArrow.add(labelB);
    bArrowsGroup.add(mainBArrow);

    // Background arrows to visualize the uniform nature of the magnetic field
    for(let z = -2.5; z <= 2.5; z+=2.5) {
        for(let y = 0.5; y <= 2.5; y+=2) {
            if(z === 0 && y === 0.5) continue; // Skip center to avoid cluttering main objects
            const arr = new THREE.ArrowHelper(new THREE.Vector3(1,0,0), new THREE.Vector3(-3, y, z), 6, 0x1e3a8a, 0.3, 0.15);
            bArrowsGroup.add(arr);
        }
    }

    // --- 2. The Current-Carrying Wire ---
    const wireMat = new THREE.MeshPhongMaterial({ color: 0xb45309 }); // Copper color
    const wireGeom = new THREE.CylinderGeometry(0.06, 0.06, 1, 16);
    wireGeom.rotateX(Math.PI / 2); // Align cylinder along Z-axis initially instead of default Y-axis
    const wireMesh = new THREE.Mesh(wireGeom, wireMat);
    scene.add(wireMesh);

    // Electric Current (I) Vector Arrow
    const iColor = 0xeab308; // Yellow
    const iArrow = new THREE.ArrowHelper(new THREE.Vector3(0,0,1), new THREE.Vector3(0,0,0), 2, iColor, 0.4, 0.2);
    scene.add(iArrow);
    const labelI = createVectorLabel('I', 'label-i');
    scene.add(labelI);

    // --- 3. Magnetic Force (F) Vector Arrow ---
    const fColor = 0xef4444; // Red
    const fArrow = new THREE.ArrowHelper(new THREE.Vector3(0,1,0), new THREE.Vector3(0,0,0), 2, fColor, 0.6, 0.3);
    scene.add(fArrow);
    const labelF = createVectorLabel('F', 'label-f');
    scene.add(labelF);

    // --- 4. Theta (Angle) Arc Visualization ---
    // Sector mesh (semi-transparent interior)
    const thetaMat = new THREE.MeshBasicMaterial({ color: 0xc084fc, side: THREE.DoubleSide, transparent: true, opacity: 0.3 });
    const thetaSectorMesh = new THREE.Mesh(new THREE.BufferGeometry(), thetaMat);
    scene.add(thetaSectorMesh);

    // Arc line (outer boundary)
    const thetaLineMat = new THREE.LineBasicMaterial({ color: 0x9333ea, linewidth: 2 });
    const thetaLineMesh = new THREE.Line(new THREE.BufferGeometry(), thetaLineMat);
    scene.add(thetaLineMesh);

    // Angle label
    const labelTheta = createVectorLabel('&theta;', 'label-theta');
    scene.add(labelTheta);


    /**
     * ==========================================
     * Core Simulation Logic
     * ==========================================
     */
    
    /**
     * Renders the step-by-step mathematical breakdown in the UI panel.
     * Extracts strings from the active translation dictionary for i18n support.
     */
    function updateMathCalculation(force, sinVal) {
        const dict = translations[currentLang];
        
        const i_str = state.I.toFixed(1);
        const l_str = state.L.toFixed(1);
        const b_str = state.B.toFixed(1);
        const theta_str = state.Theta;
        const sin_str = sinVal.toFixed(3);
        const f_str = force.toFixed(2);

        let html = `
            <div class="mb-2 text-slate-300">
                ${dict.mathEqTitle} &nbsp; <span class="text-xl text-white math-font italic">F = I &middot; L &middot; B &middot; sin(&theta;)</span>
            </div>
            
            <div class="mb-2 pl-4 border-l-2 border-slate-600">
                ${dict.mathSub}
                <div class="mt-1">
                    <span class="text-white math-font italic">F</span> = 
                    <span class="text-yellow-400">(${i_str} A)</span> &times; 
                    <span class="text-slate-300">(${l_str} m)</span> &times; 
                    <span class="text-blue-400">(${b_str} T)</span> &times; 
                    <span class="text-purple-400">sin(${theta_str}&deg;)</span>
                </div>
            </div>
            
            <div class="mb-3 pl-4 border-l-2 border-slate-600">
                ${dict.mathCalc}
                <div class="mt-1">
                    <span class="text-white math-font italic">F</span> = 
                    <span class="text-slate-200">(${(state.I * state.L * state.B).toFixed(2)})</span> &times; 
                    <span class="text-purple-400">(${sin_str})</span>
                </div>
            </div>
            
            <div class="mt-4 pt-3 border-t border-slate-700">
                ${dict.mathResult}
                <div class="text-3xl font-bold text-red-400 mt-2">
                    <span class="math-font italic">F</span> = ${f_str} <span class="text-xl text-slate-300 font-normal">${dict.mathNewton}</span>
                </div>
            </div>
        `;
        
        ui.mathOutput.innerHTML = html;
    }

    /**
     * Master function called whenever an input slider changes.
     * Recalculates vectors, applies rotations, handles visibility logic, and updates UI.
     */
    function updateSimulation() {
        // 1. Process Math
        const thetaRad = state.Theta * (Math.PI / 180);
        let sinTheta = Math.sin(thetaRad);
        
        // Compensate for floating-point inaccuracy (e.g. sin(180) resulting in 1.22e-16)
        if (Math.abs(sinTheta) < 0.0001) sinTheta = 0;
        
        const force = state.I * state.L * state.B * Math.abs(sinTheta);

        // 2. Update UI Number displays
        ui.valI.textContent = state.I.toFixed(1);
        ui.valB.textContent = state.B.toFixed(1);
        ui.valL.textContent = state.L.toFixed(1);
        ui.valTheta.textContent = state.Theta;

        updateMathCalculation(force, sinTheta);

        // 3. Update 3D Geometry Vectors
        
        // Magnetic Field (B) is fixed pointing to +X.
        
        // Calculate Current Vector (I) direction.
        // It lives on the X-Z plane. At 0 deg it aligns with +X. At 90 deg it points +Z.
        const dirI = new THREE.Vector3(Math.cos(thetaRad), 0, Math.sin(thetaRad));
        
        // Rotate the visual wire mesh to align with Current (I) Vector using Quaternions
        const defaultZ = new THREE.Vector3(0,0,1);
        const quaternion = new THREE.Quaternion().setFromUnitVectors(defaultZ, dirI.normalize());
        wireMesh.setRotationFromQuaternion(quaternion);
        wireMesh.scale.set(1, 1, state.L * 4); // Scale visual length appropriately
        
        // Update Current Arrow and Label
        iArrow.setDirection(dirI.normalize());
        if (state.I <= 0.1) {
            iArrow.visible = false;
            labelI.visible = false;
        } else {
            iArrow.visible = true;
            labelI.visible = true;
            const visLengthI = 1 + (state.I * 0.2); // Base + Dynamic length
            iArrow.setLength(visLengthI, 0.4, 0.2);
            // Translate label to sit at the tip of the arrow
            labelI.position.copy(dirI).multiplyScalar(visLengthI).add(new THREE.Vector3(0, 0.4, 0));
        }

        // Update Magnetic Field Arrow and Label
        if (state.B <= 0.1) {
            mainBArrow.visible = false;
            bArrowsGroup.visible = false;
            labelB.visible = false;
        } else {
            mainBArrow.visible = true;
            bArrowsGroup.visible = true;
            labelB.visible = true;
            const visLengthB = 2 + (state.B * 0.5);
            mainBArrow.setLength(visLengthB, 0.5, 0.25);
            labelB.position.set(visLengthB + 0.3, 0.4, 0); 
        }

        // --- Cross Product for Force Vector ---
        // Formula: F = I x B
        const vecI = dirI.clone().multiplyScalar(state.I);
        const vecB = new THREE.Vector3(1, 0, 0).multiplyScalar(state.B);
        const vecF = new THREE.Vector3().crossVectors(vecI, vecB);
        
        if (vecF.length() < 0.01) {
            fArrow.visible = false;
            labelF.visible = false;
        } else {
            fArrow.visible = true;
            labelF.visible = true;
            const dirF = vecF.clone().normalize();
            fArrow.setDirection(dirF);
            
            // Limit max visual length of Force arrow to prevent it blowing up out of screen
            const maxVisF = 6;
            const visLengthF = Math.min(1 + (force * 0.15), maxVisF);
            fArrow.setLength(visLengthF, 0.6, 0.3);
            
            // Place F label near tip
            labelF.position.copy(dirF).multiplyScalar(visLengthF).add(new THREE.Vector3(0.2, 0.2, 0));
        }

        // --- Update visual Theta Arc (Angle Indicator) ---
        if (state.Theta === 0 || state.I <= 0.1 || state.B <= 0.1) {
            // Hide arc if angle is zero or required vectors are null
            thetaSectorMesh.visible = false;
            thetaLineMesh.visible = false;
            labelTheta.visible = false;
        } else {
            thetaSectorMesh.visible = true;
            thetaLineMesh.visible = true;
            labelTheta.visible = true;

            const radius = 1.2;
            const segments = 32;
            const vertices = [0, 0, 0]; // Start at origin for filled sector
            const linePoints = [];

            // Calculate points along the arc curve
            for (let i = 0; i <= segments; i++) {
                const t = (i / segments) * thetaRad;
                const x = radius * Math.cos(t);
                const z = radius * Math.sin(t);
                vertices.push(x, 0, z);
                linePoints.push(new THREE.Vector3(x, 0, z));
            }

            // Create index triangles for the sector mesh
            const indices = [];
            for (let i = 1; i <= segments; i++) {
                indices.push(0, i, i + 1);
            }

            // Apply newly calculated geometries
            if (thetaSectorMesh.geometry) thetaSectorMesh.geometry.dispose();
            const sectorGeom = new THREE.BufferGeometry();
            sectorGeom.setAttribute('position', new THREE.Float32BufferAttribute(vertices, 3));
            sectorGeom.setIndex(indices);
            thetaSectorMesh.geometry = sectorGeom;

            if (thetaLineMesh.geometry) thetaLineMesh.geometry.dispose();
            thetaLineMesh.geometry = new THREE.BufferGeometry().setFromPoints(linePoints);

            // Position label exactly midway across the arc
            const labelRadius = radius + 0.4;
            labelTheta.position.set(
                labelRadius * Math.cos(thetaRad / 2),
                0.1, // Slight Y lift to prevent clipping with grid
                labelRadius * Math.sin(thetaRad / 2)
            );
            labelTheta.element.innerHTML = `<span class="math-font">&theta; = ${state.Theta}&deg;</span>`;
        }
    }

    /**
     * ==========================================
     * Event Listeners & Utilities
     * ==========================================
     */

    // Attach event listeners to input sliders to trigger recalculation
    ui.sliderI.addEventListener('input', (e) => { state.I = parseFloat(e.target.value); updateSimulation(); });
    ui.sliderB.addEventListener('input', (e) => { state.B = parseFloat(e.target.value); updateSimulation(); });
    ui.sliderL.addEventListener('input', (e) => { state.L = parseFloat(e.target.value); updateSimulation(); });
    ui.sliderTheta.addEventListener('input', (e) => { state.Theta = parseInt(e.target.value); updateSimulation(); });

    /**
     * Manages predetermined camera viewing angles
     */
    window.setCameraView = function(view) {
        const targetPos = new THREE.Vector3();
        switch(view) {
            case 'top': targetPos.set(0, 10, 0); break;
            case 'front': targetPos.set(0, 0, 10); break;
            case 'side': targetPos.set(10, 0, 0); break;
            case 'reset': targetPos.copy(defaultCameraPos); break;
        }
        
        camera.position.copy(targetPos);
        camera.lookAt(0,0,0);
        controls.target.set(0,0,0);
        controls.update(); // Crucial: must update controls to match new camera position
    };

    // Handle responsive container resizing
    window.addEventListener('resize', () => {
        const width = container.clientWidth;
        const height = container.clientHeight;
        
        camera.aspect = width / height;
        camera.updateProjectionMatrix();
        
        renderer.setSize(width, height);
        labelRenderer.setSize(width, height);
    });

    /**
     * Main Animation/Render Loop
     */
    window.onload = function() {
        setLanguage('en'); // Enforce default language on initialization
        updateSimulation(); // Initial physics draw
        
        function animate() {
            requestAnimationFrame(animate);
            controls.update(); // Enable smooth damping for camera
            renderer.render(scene, camera); // Render WebGL scene
            labelRenderer.render(scene, camera); // Render synced HTML 2D overlay labels
        }
        animate();
    };

</script>
</body>
</html>
